DATABASE_URL=postgresql+psycopg://resolveops:resolveops@postgres:5432/resolveops

# ERPNext API credentials. Create an API Key/Secret from an ERPNext user.
ERPNEXT_BASE_URL=http://erpnext:8000
ERPNEXT_API_KEY=replace-me
ERPNEXT_API_SECRET=replace-me

# Webhook and operator boundary.
WEBHOOK_SECRET=replace-me
OPERATOR_API_KEY=replace-me
# Optional local bootstrap: subject:role:key;subject:role:key
OPERATOR_SEED_KEYS=local-sales:sales_manager:replace-sales-key;local-finance:finance_manager:replace-finance-key;local-warehouse:warehouse_manager:replace-warehouse-key;local-procurement:procurement_manager:replace-procurement-key

# LLM chat-completions compatible endpoint.
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=replace-me
LLM_MODEL=replace-me

# Runtime safety budgets.
TASK_LEASE_SECONDS=90
AGENT_MAX_INVESTIGATION_TURNS=8
AGENT_MAX_READ_TOOL_CALLS=12
AGENT_READ_TOOL_PARALLELISM=4
AGENT_MAX_REPLANS=2

# Fallback only when logistics_lanes config is not available.
ALTERNATIVE_WAREHOUSES=重庆仓 - ROPS
